{
	"schemaVersion": 1,
	"id": "player_to_player",
	"version": "${version}",
	"name": "Player to Player",
	"description": "P2P 分布式算力模组：通过玩家间 P2P 打洞连接，将服务器的世界运算全部下放给玩家客户端，由多台客户端分担世界主线程运算。",
	"authors": [
		"IMSng"
	],
	"contact": {},
	"license": "MIT",
	"icon": "assets/player_to_player/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"imsng.player_to_player.Player_to_player"
		],
		"client": [
			"imsng.player_to_player.client.Player_to_playerClient"
		]
	},
	"mixins": [
		"player_to_player.mixins.json",
		{
			"config": "player_to_player.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.20.4",
		"java": ">=17",
		"fabric-api": "*"
	}
}